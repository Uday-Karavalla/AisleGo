# Base URL of the AisleGo backend REST API.
# Leave unset to default to "/api" (useful behind a dev-server proxy or reverse proxy in prod).
# If the backend isn't running yet, Store Discovery and Storefront fall back to
# bundled sample data automatically (see src/api/fixtures.ts) so the UI stays usable.
VITE_API_BASE_URL=http://localhost:8080/api
